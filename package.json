{
  "name": "git-worklists",
  "displayName": "Git Worklists",
  "description": "IntelliJ-style changelists for VS Code. Organize changes into work units, stage selectively, and commit with full control.",
  "publisher": "ozgen",
  "version": "1.1.0",
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.109.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ozgen/git-worklists.git"
  },
  "license": "MIT",
  "homepage": "https://github.com/ozgen/git-worklists",
  "bugs": {
    "url": "https://github.com/ozgen/git-worklists/issues"
  },
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "keywords": [
    "git",
    "git workflow",
    "git staging",
    "explicit staging",
    "partial staging",
    "stage selected lines",
    "line staging",
    "changelist",
    "changelists",
    "intellij changelist",
    "intellij changelists",
    "intellij",
    "organize changes",
    "group changes",
    "work units",
    "stash",
    "stash management",
    "commit",
    "amend",
    "commit and push",
    "source control",
    "diff view",
    "diff preview",
    "conventional commits",
    "commit message",
    "semantic commits",
    "bookmark",
    "bookmarks",
    "editor bookmarks",
    "code navigation",
    "jump to bookmark",
    "quick navigation",
    "intellij bookmark",
    "intellij bookmarks"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Git Worklists",
      "properties": {
        "gitWorklists.promptOnNewFile": {
          "type": "boolean",
          "default": true,
          "description": "Prompt to add new files to Git when they are created."
        },
        "gitWorklists.ui.closeDiffTabsAfterCommit": {
          "type": "boolean",
          "default": false,
          "description": "Close diff tabs opened by Git Worklists after a successful commit."
        },
        "gitWorklists.ui.closeDiffTabsAfterPush": {
          "type": "boolean",
          "default": false,
          "description": "Close diff tabs opened by Git Worklists after a successful push."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "gitWorklists",
          "title": "Git Worklists",
          "icon": "media/activity-icon.png"
        }
      ]
    },
    "views": {
      "gitWorklists": [
        {
          "id": "gitWorklists.changelists",
          "name": "Changelists",
          "icon": "media/activity-icon.png"
        },
        {
          "id": "gitWorklists.commitPanel",
          "name": "Commit",
          "type": "webview",
          "icon": "media/activity-icon.png"
        },
        {
          "id": "gitWorklists.stashes",
          "name": "Stashes",
          "icon": "media/activity-icon.png"
        }
      ]
    },
    "commands": [
      {
        "command": "gitWorklists.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "gitWorklists.createChangelist",
        "title": "Create Changelist…",
        "icon": "$(add)"
      },
      {
        "command": "gitWorklists.moveFileToChangelist",
        "title": "Move to Changelist…",
        "icon": "$(folder)"
      },
      {
        "command": "gitWorklists.moveGroupToChangelist",
        "title": "Move All Files to Changelist…",
        "icon": "$(folder)"
      },
      {
        "command": "gitWorklists.renameChangelist",
        "title": "Rename Changelist…",
        "icon": "$(edit)"
      },
      {
        "command": "gitWorklists.deleteChangelist",
        "title": "Delete Changelist…",
        "icon": "$(trash)"
      },
      {
        "command": "gitWorklists.selectFile",
        "title": "Stage File",
        "icon": "$(check)"
      },
      {
        "command": "gitWorklists.unselectFile",
        "title": "Unstage File",
        "icon": "$(circle-slash)"
      },
      {
        "command": "gitWorklists.toggleGroupSelection",
        "title": "Toggle Group Staging",
        "icon": "$(checklist)"
      },
      {
        "command": "gitWorklists.stash.refresh",
        "title": "Refresh Stashes",
        "icon": "$(refresh)"
      },
      {
        "command": "gitWorklists.stash.createFromChangelist",
        "title": "Stash changes…",
        "icon": "$(archive)"
      },
      {
        "command": "gitWorklists.stash.apply",
        "title": "Apply Stash",
        "icon": "$(output)"
      },
      {
        "command": "gitWorklists.stash.pop",
        "title": "Pop Stash",
        "icon": "$(arrow-up)"
      },
      {
        "command": "gitWorklists.stash.drop",
        "title": "Delete Stash",
        "icon": "$(trash)"
      },
      {
        "command": "gitWorklists.file.discard",
        "title": "Discard",
        "icon": "$(discard)"
      },
      {
        "command": "gitWorklists.openDiff",
        "title": "Git Worklists: Open Diff (HEAD <-> Working Tree)"
      },
      {
        "command": "gitWorklists.closeDiffTabs",
        "title": "Close Diff Tabs",
        "category": "Git Worklists",
        "icon": "$(close)"
      },
      {
        "command": "gitWorklists.stageChangelistAll",
        "title": "Stage All in Changelist",
        "icon": "$(check-all)"
      },
      {
        "command": "gitWorklists.unstageChangelistAll",
        "title": "Unstage All in Changelist",
        "icon": "$(circle-slash)"
      },
      {
        "command": "gitWorklists.changelist.discardAll",
        "title": "Discard All Changes"
      },
      {
        "command": "gitWorklists.file.openSource",
        "title": "Open Source",
        "icon": "$(go-to-file)"
      },
      {
        "command": "gitWorklists.moveAllStagedFilesToChangelist",
        "title": "Move All Staged Files to Changelist…",
        "icon": "$(folder)"
      },
      {
        "command": "gitWorklists.stashAllStagedFiles",
        "title": "Stash All Staged Files…",
        "icon": "$(archive)"
      },
      {
        "command": "gitWorklists.switchRepoRoot",
        "title": "Switch Git Root…",
        "icon": "$(list-tree)"
      },
      {
        "command": "gitWorklists.stageSelectedLines",
        "title": "GW: Stage Selected Lines",
        "category": "Git Worklists"
      },
      {
        "command": "gitWorklists.bookmark.set",
        "title": "GW:Set Bookmark…",
        "icon": "$(bookmark)"
      },
      {
        "command": "gitWorklists.bookmark.clear",
        "title": "GW: Clear Bookmark...",
        "icon": "$(bookmark-slash)"
      },
      {
        "command": "gitWorklists.bookmark.clearAll",
        "title": "GW: Clear All Bookmarks",
        "icon": "$(clear-all)"
      },
      {
        "command": "gitWorklists.bookmark.set1",
        "title": "Set Bookmark 1"
      },
      {
        "command": "gitWorklists.bookmark.set2",
        "title": "Set Bookmark 2"
      },
      {
        "command": "gitWorklists.bookmark.set3",
        "title": "Set Bookmark 3"
      },
      {
        "command": "gitWorklists.bookmark.set4",
        "title": "Set Bookmark 4"
      },
      {
        "command": "gitWorklists.bookmark.set5",
        "title": "Set Bookmark 5"
      },
      {
        "command": "gitWorklists.bookmark.set6",
        "title": "Set Bookmark 6"
      },
      {
        "command": "gitWorklists.bookmark.set7",
        "title": "Set Bookmark 7"
      },
      {
        "command": "gitWorklists.bookmark.set8",
        "title": "Set Bookmark 8"
      },
      {
        "command": "gitWorklists.bookmark.set9",
        "title": "Set Bookmark 9"
      },
      {
        "command": "gitWorklists.bookmark.jump1",
        "title": "Jump to Bookmark 1"
      },
      {
        "command": "gitWorklists.bookmark.jump2",
        "title": "Jump to Bookmark 2"
      },
      {
        "command": "gitWorklists.bookmark.jump3",
        "title": "Jump to Bookmark 3"
      },
      {
        "command": "gitWorklists.bookmark.jump4",
        "title": "Jump to Bookmark 4"
      },
      {
        "command": "gitWorklists.bookmark.jump5",
        "title": "Jump to Bookmark 5"
      },
      {
        "command": "gitWorklists.bookmark.jump6",
        "title": "Jump to Bookmark 6"
      },
      {
        "command": "gitWorklists.bookmark.jump7",
        "title": "Jump to Bookmark 7"
      },
      {
        "command": "gitWorklists.bookmark.jump8",
        "title": "Jump to Bookmark 8"
      },
      {
        "command": "gitWorklists.bookmark.jump9",
        "title": "Jump to Bookmark 9"
      },
      {
        "command": "gitWorklists.bookmark.clear1",
        "title": "Clear Bookmark 1"
      },
      {
        "command": "gitWorklists.bookmark.clear2",
        "title": "Clear Bookmark 2"
      },
      {
        "command": "gitWorklists.bookmark.clear3",
        "title": "Clear Bookmark 3"
      },
      {
        "command": "gitWorklists.bookmark.clear4",
        "title": "Clear Bookmark 4"
      },
      {
        "command": "gitWorklists.bookmark.clear5",
        "title": "Clear Bookmark 5"
      },
      {
        "command": "gitWorklists.bookmark.clear6",
        "title": "Clear Bookmark 6"
      },
      {
        "command": "gitWorklists.bookmark.clear7",
        "title": "Clear Bookmark 7"
      },
      {
        "command": "gitWorklists.bookmark.clear8",
        "title": "Clear Bookmark 8"
      },
      {
        "command": "gitWorklists.bookmark.clear9",
        "title": "Clear Bookmark 9"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "gitWorklists.createChangelist",
          "when": "view == gitWorklists.changelists",
          "group": "navigation@0"
        },
        {
          "command": "gitWorklists.refresh",
          "when": "view == gitWorklists.changelists",
          "group": "navigation@1"
        },
        {
          "command": "gitWorklists.closeDiffTabs",
          "when": "view == gitWorklists.changelists",
          "group": "navigation@2"
        },
        {
          "command": "gitWorklists.stash.refresh",
          "when": "view == gitWorklists.stashes",
          "group": "navigation@1"
        },
        {
          "command": "gitWorklists.bookmark.clearAll",
          "when": "view == gitWorklists.changelists",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "gitWorklists.moveFileToChangelist",
          "when": "view == gitWorklists.changelists && (viewItem == gitWorklists.file.staged || viewItem == gitWorklists.file.partial || viewItem == gitWorklists.file.unstaged)",
          "group": "navigation@0"
        },
        {
          "command": "gitWorklists.moveGroupToChangelist",
          "when": "view == gitWorklists.changelists && (viewItem == gitWorklists.group.custom || viewItem == gitWorklists.group.system)",
          "group": "navigation@0"
        },
        {
          "command": "gitWorklists.changelist.discardAll",
          "when": "view == gitWorklists.changelists && (viewItem == gitWorklists.group.custom || viewItem == gitWorklists.group.system)",
          "group": "navigation@1"
        },
        {
          "command": "gitWorklists.renameChangelist",
          "when": "view == gitWorklists.changelists && viewItem == gitWorklists.group.custom",
          "group": "navigation@8"
        },
        {
          "command": "gitWorklists.deleteChangelist",
          "when": "view == gitWorklists.changelists && viewItem == gitWorklists.group.custom",
          "group": "navigation@9"
        },
        {
          "command": "gitWorklists.toggleGroupSelection",
          "when": "view == gitWorklists.changelists && viewItem == gitWorklists.group",
          "group": "inline@1"
        },
        {
          "command": "gitWorklists.selectFile",
          "when": "view == gitWorklists.changelists && (viewItem == gitWorklists.file.unstaged || viewItem == gitWorklists.file.partial)",
          "group": "inline@1"
        },
        {
          "command": "gitWorklists.unselectFile",
          "when": "view == gitWorklists.changelists && (viewItem == gitWorklists.file.staged || viewItem == gitWorklists.file.partial)",
          "group": "inline@2"
        },
        {
          "command": "gitWorklists.file.discard",
          "when": "view == gitWorklists.changelists && (viewItem == gitWorklists.file.staged || viewItem == gitWorklists.file.partial || viewItem == gitWorklists.file.unstaged)",
          "group": "inline@3"
        },
        {
          "command": "gitWorklists.stageChangelistAll",
          "when": "view == gitWorklists.changelists && (viewItem == gitWorklists.group.custom || viewItem == gitWorklists.group.system)",
          "group": "inline@1"
        },
        {
          "command": "gitWorklists.unstageChangelistAll",
          "when": "view == gitWorklists.changelists && (viewItem == gitWorklists.group.custom || viewItem == gitWorklists.group.system)",
          "group": "inline@2"
        },
        {
          "command": "gitWorklists.stash.createFromChangelist",
          "when": "view == gitWorklists.changelists && viewItem == gitWorklists.group.custom",
          "group": "inline@3"
        },
        {
          "command": "gitWorklists.stash.createFromChangelist",
          "when": "view == gitWorklists.changelists && viewItem == gitWorklists.group.system",
          "group": "inline@3"
        },
        {
          "command": "gitWorklists.stash.apply",
          "when": "view == gitWorklists.stashes && viewItem == gitWorklists.stashItem",
          "group": "inline@1"
        },
        {
          "command": "gitWorklists.stash.pop",
          "when": "view == gitWorklists.stashes && viewItem == gitWorklists.stashItem",
          "group": "inline@2"
        },
        {
          "command": "gitWorklists.stash.drop",
          "when": "view == gitWorklists.stashes && viewItem == gitWorklists.stashItem",
          "group": "inline@9"
        },
        {
          "command": "gitWorklists.file.openSource",
          "when": "view == gitWorklists.changelists && (viewItem == gitWorklists.file.staged || viewItem == gitWorklists.file.partial || viewItem == gitWorklists.file.unstaged)",
          "group": "navigation@0"
        },
        {
          "command": "gitWorklists.moveAllStagedFilesToChangelist",
          "when": "view == gitWorklists.changelists && (viewItem == gitWorklists.file.staged || viewItem == gitWorklists.file.partial)",
          "group": "navigation@5"
        },
        {
          "command": "gitWorklists.stashAllStagedFiles",
          "when": "view == gitWorklists.changelists && (viewItem == gitWorklists.file.staged || viewItem == gitWorklists.file.partial)",
          "group": "navigation@6"
        }
      ],
      "editor/context": [
        {
          "command": "gitWorklists.stageSelectedLines",
          "when": "editorHasSelection && !editorReadonly",
          "group": "gitWorklists@1"
        },
        {
          "command": "gitWorklists.bookmark.set",
          "when": "!editorReadonly",
          "group": "gitWorklists@2"
        },
        {
          "command": "gitWorklists.bookmark.clear",
          "when": "!editorReadonly",
          "group": "gitWorklists@3"
        },
        {
          "command": "gitWorklists.bookmark.clearAll",
          "when": "!editorReadonly",
          "group": "gitWorklists@4"
        }
      ]
    },
    "keybindings": [
      {
        "command": "gitWorklists.bookmark.set1",
        "key": "ctrl+shift+1",
        "mac": "cmd+shift+1",
        "when": "editorTextFocus && !editorReadonly"
      },
      {
        "command": "gitWorklists.bookmark.jump1",
        "key": "ctrl+1",
        "mac": "cmd+1",
        "when": "editorTextFocus"
      },
      {
        "command": "gitWorklists.bookmark.set2",
        "key": "ctrl+shift+2",
        "mac": "cmd+shift+2",
        "when": "editorTextFocus && !editorReadonly"
      },
      {
        "command": "gitWorklists.bookmark.jump2",
        "key": "ctrl+2",
        "mac": "cmd+2",
        "when": "editorTextFocus"
      },
      {
        "command": "gitWorklists.bookmark.set3",
        "key": "ctrl+shift+3",
        "mac": "cmd+shift+3",
        "when": "editorTextFocus && !editorReadonly"
      },
      {
        "command": "gitWorklists.bookmark.jump3",
        "key": "ctrl+3",
        "mac": "cmd+3",
        "when": "editorTextFocus"
      },
      {
        "command": "gitWorklists.bookmark.set4",
        "key": "ctrl+shift+4",
        "mac": "cmd+shift+4",
        "when": "editorTextFocus && !editorReadonly"
      },
      {
        "command": "gitWorklists.bookmark.jump4",
        "key": "ctrl+4",
        "mac": "cmd+4",
        "when": "editorTextFocus"
      },
      {
        "command": "gitWorklists.bookmark.set5",
        "key": "ctrl+shift+5",
        "mac": "cmd+shift+5",
        "when": "editorTextFocus && !editorReadonly"
      },
      {
        "command": "gitWorklists.bookmark.jump5",
        "key": "ctrl+5",
        "mac": "cmd+5",
        "when": "editorTextFocus"
      },
      {
        "command": "gitWorklists.bookmark.set6",
        "key": "ctrl+shift+6",
        "mac": "cmd+shift+6",
        "when": "editorTextFocus && !editorReadonly"
      },
      {
        "command": "gitWorklists.bookmark.jump6",
        "key": "ctrl+6",
        "mac": "cmd+6",
        "when": "editorTextFocus"
      },
      {
        "command": "gitWorklists.bookmark.set7",
        "key": "ctrl+shift+7",
        "mac": "cmd+shift+7",
        "when": "editorTextFocus && !editorReadonly"
      },
      {
        "command": "gitWorklists.bookmark.jump7",
        "key": "ctrl+7",
        "mac": "cmd+7",
        "when": "editorTextFocus"
      },
      {
        "command": "gitWorklists.bookmark.set8",
        "key": "ctrl+shift+8",
        "mac": "cmd+shift+8",
        "when": "editorTextFocus && !editorReadonly"
      },
      {
        "command": "gitWorklists.bookmark.jump8",
        "key": "ctrl+8",
        "mac": "cmd+8",
        "when": "editorTextFocus"
      },
      {
        "command": "gitWorklists.bookmark.set9",
        "key": "ctrl+shift+9",
        "mac": "cmd+shift+9",
        "when": "editorTextFocus && !editorReadonly"
      },
      {
        "command": "gitWorklists.bookmark.jump9",
        "key": "ctrl+9",
        "mac": "cmd+9",
        "when": "editorTextFocus"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "npm run test:unit && npm run test:ext",
    "test:unit": "vitest run",
    "test:unit:cov": "vitest run --coverage",
    "test:unit:watch": "vitest",
    "compile:integration": "tsc -p tsconfig.integration.json",
    "test:ext": "npm run compile:integration && node ./out/test/integration/runIntegrationTests.js",
    "release:patch": "npm version patch -m \"chore(release): v%s\"",
    "release:minor": "npm version minor -m \"chore(release): v%s\"",
    "release:major": "npm version major -m \"chore(release): v%s\""
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.15",
    "@types/vscode": "^1.109.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "vitest": "^4.0.18"
  }
}
